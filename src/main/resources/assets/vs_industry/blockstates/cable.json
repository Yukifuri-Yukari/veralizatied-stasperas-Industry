{
  "multipart": [
    { "apply": { "model": "vs_industry:block/cable_core" } },
    { "when": { "north": "true" }, "apply": { "model": "vs_industry:block/cable_connection" } },
    { "when": { "east": "true" },  "apply": { "model": "vs_industry:block/cable_connection", "y": 90 } },
    { "when": { "south": "true" }, "apply": { "model": "vs_industry:block/cable_connection", "y": 180 } },
    { "when": { "west": "true" },  "apply": { "model": "vs_industry:block/cable_connection", "y": 270 } },
    { "when": { "up": "true" },    "apply": { "model": "vs_industry:block/cable_connection", "x": 270 } },
    { "when": { "down": "true" },  "apply": { "model": "vs_industry:block/cable_connection", "x": 90 } }
  ]
}